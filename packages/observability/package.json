{
  "name": "@commander/observability",
  "version": "0.1.0",
  "description": "Commander Observability — metrics, tracing, and monitoring for multi-agent orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "commander",
    "multi-agent",
    "observability",
    "metrics",
    "tracing",
    "monitoring",
    "opentelemetry"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander",
    "directory": "packages/observability"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-cache",
    "test:watch": "vitest",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@commander/core": "workspace:*",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  },
  "peerDependencies": {
    "@commander/core": "^0.2.0"
  }
}
