{
  "name": "@commander/operations",
  "version": "0.2.0",
  "type": "module",
  "description": "Commander operations plane — durable outbox publishing, evidence timelines, timer wakeup, and SLO evaluation",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./timerWakeupWorker": {
      "types": "./dist/timerWakeupWorker.d.ts",
      "default": "./dist/timerWakeupWorker.js"
    },
    "./compensationConsumer": {
      "types": "./dist/compensationConsumer.d.ts",
      "default": "./dist/compensationConsumer.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --workspace-root exec tsx --test packages/operations/src/operations.test.ts",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "keywords": [
    "commander",
    "operations",
    "outbox",
    "slo",
    "multi-agent",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander",
    "directory": "packages/operations"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@commander/contracts": "workspace:*",
    "@commander/kernel": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
