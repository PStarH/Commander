{
  "name": "@commander/core",
  "version": "0.2.0",
  "type": "module",
  "description": "Multi-agent orchestration system. Dynamic topology, quality gates, 18 built-in tools, 25 LLM providers.",
  "bin": {
    "commander": "./dist/cliEntry.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runtime/*": {
      "types": "./dist/runtime/*.d.ts",
      "default": "./dist/runtime/*.js"
    },
    "./saga": {
      "types": "./dist/saga/index.d.ts",
      "default": "./dist/saga/index.js"
    },
    "./saga/*": {
      "types": "./dist/saga/*.d.ts",
      "default": "./dist/saga/*.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "default": "./dist/security/index.js"
    },
    "./security/*": {
      "types": "./dist/security/*.d.ts",
      "default": "./dist/security/*.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    },
    "./observability/*": {
      "types": "./dist/observability/*.d.ts",
      "default": "./dist/observability/*.js"
    },
    "./plugins/im/dingtalk": {
      "types": "./dist/plugins/im/dingtalk/index.d.ts",
      "default": "./dist/plugins/im/dingtalk/index.js"
    },
    "./plugins/im/feishu": {
      "types": "./dist/plugins/im/feishu/index.d.ts",
      "default": "./dist/plugins/im/feishu/index.js"
    },
    "./plugins/im/wecom": {
      "types": "./dist/plugins/im/wecom/index.d.ts",
      "default": "./dist/plugins/im/wecom/index.js"
    },
    "./plugins/im/slack": {
      "types": "./dist/plugins/im/slack/index.d.ts",
      "default": "./dist/plugins/im/slack/index.js"
    },
    "./plugins/im/teams": {
      "types": "./dist/plugins/im/teams/index.d.ts",
      "default": "./dist/plugins/im/teams/index.js"
    },
    "./plugins/im/discord": {
      "types": "./dist/plugins/im/discord/index.d.ts",
      "default": "./dist/plugins/im/discord/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "multi-agent",
    "ai",
    "orchestration",
    "llm",
    "agents",
    "workflow",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "test": "vitest run --no-cache",
    "test:quick": "vitest run --no-cache tests/ultimate/deliberation.test.ts tests/tools/pathSecurity.test.ts tests/security/",
    "test:algorithmic": "vitest run --no-cache tests/benchmarks/algorithmicEffectiveness",
    "test:coverage:core": "node scripts/core-coverage.mjs",
    "benchmark:algorithmic:live": "tsx src/benchmarks/algorithmicEffectiveness/cli.ts live",
    "test:inventory": "node scripts/test-inventory.mjs --verify",
    "test:node": "node scripts/run-node-tests.mjs",
    "test:slo": "vitest run --no-cache tests/e2e/sloMeasurement.test.ts",
    "test:load": "vitest run --no-cache tests/e2e/load.test.ts",
    "test:chaos": "vitest run --no-cache tests/e2e/chaos.test.ts",
    "test:e2e": "vitest run --no-cache tests/e2e/",
    "bench": "npx tsx --test --test-concurrency=1 tests/cpu-intensive-benchmark.test.ts tests/worker-offload-benchmark.test.ts",
    "benchmark:verify": "node scripts/verify-benchmark-results.mjs || echo 'BFCL results not available — skipping'",
    "test:vitest": "vitest run --no-cache",
    "test:vitest:watch": "vitest",
    "prepublishOnly": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "test:node:pathsec": "npx tsx --test --test-concurrency=1 tests/tools/pathSecurity.test.ts",
    "test:security": "npx tsx --test tests/tools-security.test.ts tests/httpServer.test.ts tests/observabilityP1.test.ts tests/observabilityP2P3.test.ts",
    "docs": "typedoc",
    "docs:serve": "typedoc --watch"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^4.8.0",
    "selfsigned": "^5.5.0",
    "tsx": "^4.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@commander/plugin-sdk": "workspace:*",
    "blessed": "^0.1.81",
    "better-sqlite3": "^12.11.1",
    "safe-regex": "^2.1.1"
  },
  "optionalDependencies": {
    "isolated-vm": "^5.0.1",
    "pg": "^8.15.0",
    "playwright": "^1.61.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
