{
  "name": "@commander/core",
  "version": "0.2.0",
  "description": "Multi-agent orchestration system. Dynamic topology, quality gates, 26 tools, 21 LLM providers.",
  "bin": {
    "commander": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runtime/*": "./dist/runtime/*",
    "./saga": {
      "types": "./dist/saga/index.d.ts",
      "default": "./dist/saga/index.js"
    },
    "./saga/*": "./dist/saga/*",
    "./security": {
      "types": "./dist/security/index.d.ts",
      "default": "./dist/security/index.js"
    },
    "./security/*": "./dist/security/*"
  },
  "keywords": [
    "multi-agent",
    "ai",
    "orchestration",
    "llm",
    "agents",
    "workflow",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --no-cache",
    "test:inventory": "node scripts/test-inventory.mjs --verify",
    "test:node": "node scripts/run-node-tests.mjs",
    "bench": "node scripts/run-node-tests.mjs benchmarks",
    "benchmark:verify": "node scripts/verify-benchmark-results.mjs",
    "test:vitest": "vitest run --no-cache",
    "test:vitest:watch": "vitest",
    "prepublishOnly": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "test:node:pathsec": "npx tsx --test --test-concurrency=1 tests/tools/pathSecurity.test.ts",
    "test:security": "npx tsx --test tests/tools-security.test.ts tests/httpServer.test.ts tests/observabilityP1.test.ts tests/observabilityP2P3.test.ts",
    "docs": "typedoc",
    "docs:serve": "typedoc --watch"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "typedoc": "^0.28.19"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "@commander/plugin-sdk": "workspace:*"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.11.1",
    "playwright": "^1.61.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
