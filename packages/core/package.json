{
  "name": "@commander/core",
  "version": "1.0.0-alpha.1",
  "description": "Multi-agent orchestration system. 70% on GAIA, dynamic topology, quality gates, 13 tools.",
  "bin": {
    "commander": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "multi-agent",
    "ai",
    "orchestration",
    "llm",
    "agents",
    "gaia",
    "workflow",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm test:node && pnpm test:vitest",
    "test:inventory": "node scripts/test-inventory.mjs --verify",
    "test:node": "node scripts/run-node-tests.mjs",
    "bench": "node scripts/run-node-tests.mjs benchmarks",
    "benchmark:verify": "node scripts/verify-benchmark-results.mjs",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "prepublishOnly": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "blessed": "^0.1.81"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
