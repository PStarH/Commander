{
  "name": "@commander/sdk",
  "version": "0.2.0",
  "description": "Commander Agent SDK — embed multi-agent orchestration in your own applications",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "keywords": [
    "commander",
    "sdk",
    "multi-agent",
    "ai",
    "orchestration",
    "typescript"
  ],
  "author": "PStarH <sampan090611@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@commander/contracts": "workspace:*"
  },
  "peerDependencies": {
    "@commander/core": "^0.2.0"
  },
  "devDependencies": {
    "@commander/contracts": "workspace:*",
    "@commander/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "tsx": "^4.8.1",
    "typescript": "^7.0.2"
  }
}
