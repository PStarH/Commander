{
  "name": "@commander/operations",
  "version": "0.2.0",
  "description": "Commander operations daemons (reconciliation, compensation)",
  "type": "module",
  "main": "dist/main.js",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm --filter @commander/contracts build && pnpm --filter @commander/effect-broker build && pnpm --filter @commander/kernel build && pnpm --filter @commander/action-adapters build",
    "test": "pnpm --workspace-root exec tsx --test packages/operations/src/**/*.test.ts",
    "start": "node dist/run.js",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "license": "MIT",
  "dependencies": {
    "@commander/action-adapters": "workspace:*",
    "@commander/contracts": "workspace:*",
    "@commander/effect-broker": "workspace:*",
    "@commander/kernel": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
