{
  "$schema": "WS9 §5.1 — env vars allowed in process.env without violating Vault-only key path",
  "description": "Only these env vars may appear in process.env in production. Any *_API_KEY, *_SECRET, *_TOKEN not in this list is a keypath violation. Secrets themselves must come from Vault, never process.env.",
  "allowed": [
    "NODE_ENV",
    "PATH",
    "HOME",
    "USER",
    "SHELL",
    "LANG",
    "LC_ALL",
    "TERM",
    "PWD",
    "SHLVL",
    "HOSTNAME",
    "COMMANDER_VAULT_ADDR",
    "COMMANDER_VAULT_TOKEN",
    "COMMANDER_VAULT_NAMESPACE",
    "COMMANDER_SANDBOX_ISOLATION",
    "COMMANDER_SANDBOX_RUNTIME",
    "COMMANDER_SANDBOX_PROFILE",
    "COMMANDER_LOG_LEVEL",
    "COMMANDER_LOG_PERSIST",
    "COMMANDER_AUDIT_PERSIST_DIR",
    "COMMANDER_AUDIT_CHAIN_KEY",
    "COMMANDER_MANIFEST_KEY",
    "COMMANDER_EVENT_SOURCING_WAL",
    "COMMANDER_DB_HOST",
    "COMMANDER_DB_PORT",
    "COMMANDER_DB_NAME",
    "COMMANDER_DB_USER",
    "COMMANDER_DB_PASSWORD",
    "COMMANDER_DB_SSLMODE",
    "COMMANDER_DB_POOL_MAX",
    "COMMANDER_REDIS_URL",
    "COMMANDER_API_PORT",
    "COMMANDER_API_HOST",
    "COMMANDER_METRICS_PORT",
    "COMMANDER_IMAGE",
    "COMMANDER_TENANT_ID",
    "COMMANDER_RUN_ID",
    "COMMANDER_OIDC_ISSUER",
    "COMMANDER_OIDC_CLIENT_ID",
    "COMMANDER_OIDC_AUDIENCE",
    "COMMANDER_JWKS_URL",
    "COMMANDER_A2A_AUTH_TOKEN",
    "COMMANDER_MTLS_CERT_PATH",
    "COMMANDER_MTLS_KEY_PATH",
    "COMMANDER_MTLS_CA_PATH",
    "COMMANDER_RATE_LIMIT_RPM",
    "COMMANDER_RATE_LIMIT_BURST",
    "COMMANDER_FAIRNESS_WINDOW_MS",
    "COMMANDER_SIEM_ENDPOINT",
    "COMMANDER_SIEM_API_KEY",
    "COMMANDER_KMS_KEY_ID",
    "COMMANDER_WORM_BUCKET",
    "COMMANDER_WORM_REGION",
    "TZ"
  ],
  "forbiddenPatterns": [
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "GOOGLE_API_KEY",
    "GEMINI_API_KEY",
    "AZURE_OPENAI_API_KEY",
    "STEPFUN_API_KEY",
    "GITHUB_TOKEN",
    "STRIPE_SECRET_KEY",
    "SLACK_BOT_TOKEN",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_ACCESS_KEY_ID"
  ],
  "notes": [
    "COMMANDER_DB_PASSWORD and COMMANDER_SIEM_API_KEY are transitional — in full Vault-only mode these should also be resolved from Vault. The keypath-scan flags them as warnings, not failures.",
    "COMMANDER_AUDIT_CHAIN_KEY and COMMANDER_MANIFEST_KEY are HMAC keys that must be injected via Vault in production. The env var is the injection mechanism, not a storage location."
  ]
}
