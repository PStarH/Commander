{
  "name": "commander-monorepo",
  "version": "0.2.0",
  "description": "Commander \u2014 Multi-Agent Orchestration System (monorepo root)",
  "private": true,
  "author": "PStarH <sampan090611@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "cd packages/core && tsc -p tsconfig.json",
    "build:mcp-server": "pnpm --filter @commander/mcp-server build",
    "test:mcp-server": "pnpm --filter @commander/mcp-server test",
    "publish:mcp-server": "pnpm --filter @commander/mcp-server publish --access public --no-git-checks",
    "release:mcp-server": "pnpm run build:mcp-server && pnpm run test:mcp-server && pnpm run publish:mcp-server",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm -r dev",
    "gui": "tsx packages/core/src/cli.ts gui",
    "start": "tsx packages/core/src/cli.ts gui",
    "test": "pnpm --filter @commander/core test",
    "test:core": "pnpm --filter @commander/core test",
    "test:bench": "pnpm --filter @commander/core bench",
    "test:coverage": "cd packages/core && pnpm exec --node-options='--experimental-coverage' tsx --test tests/*.test.ts",
    "test:all": "cd packages/core && pnpm exec tsx --test tests/*.test.ts",
    "benchmark:gaia": "pnpm exec tsx scripts/benchmark-gaia.ts",
    "benchmark:gaia:quick": "pnpm exec tsx scripts/benchmark-gaia.ts --quick",
    "benchmark:gaia:all": "pnpm exec tsx scripts/benchmark-gaia.ts --all",
    "benchmark:gaia:full": "pnpm exec tsx scripts/benchmark-gaia.ts --full",
    "benchmark:topology": "pnpm exec tsx scripts/benchmark-topology.ts",
    "benchmark:topology:quick": "pnpm exec tsx scripts/benchmark-topology.ts --iterations=3 --topology=single",
    "bench:wal": "pnpm exec tsx scripts/bench-wal-throughput.ts",
    "bench:wal:quick": "pnpm exec tsx scripts/bench-wal-throughput.ts --iterations=2000 --warmup=50",
    "bench:wal:regress": "pnpm exec tsx scripts/bench-wal-regress.ts",
    "bench:recovery": "pnpm exec tsx scripts/bench-recovery-bootstrap.ts",
    "bench:replay": "pnpm exec tsx scripts/bench-event-sourcing-replay.ts",
    "bench:slo": "pnpm exec tsx scripts/bench-slo-baseline.ts",
    "bench:slo:regress": "pnpm exec tsx scripts/bench-slo-regress.ts",
    "bench:tenant-isolation": "pnpm exec tsx scripts/bench-tenant-isolation.ts",
    "bench:cost-prediction": "pnpm exec tsx scripts/bench-cost-prediction.ts",
    "bench:e2e-latency": "pnpm exec tsx scripts/bench-e2e-latency.ts",
    "bench:tenant-concurrency": "pnpm exec tsx scripts/bench-tenant-concurrency.ts",
    "benchmark:redteam": "pnpm exec tsx scripts/benchmark-redteam.ts",
    "benchmark:agentdojo": "pnpm exec tsx scripts/benchmark-agentdojo.ts",
    "benchmark:agentdojo:all": "pnpm exec tsx scripts/benchmark-agentdojo.ts --all",
    "benchmark:webarena": "pnpm exec tsx scripts/benchmark-webarena.ts",
    "benchmark:agentbench": "pnpm exec tsx scripts/benchmark-agentbench.ts",
    "benchmark:osworld": "pnpm exec tsx scripts/benchmark-osworld.ts",
    "benchmark:crab": "pnpm exec tsx scripts/benchmark-crab.ts",
    "benchmark:swebench": "pnpm exec tsx scripts/benchmark-swebench.ts",
    "benchmark:mlcommons:ailuminate": "pnpm exec tsx scripts/benchmark-mlcommons-ailuminate.ts",
    "benchmark:caict:ai-safety": "pnpm exec tsx scripts/benchmark-caict-ai-safety.ts",
    "benchmark:chaos": "pnpm exec tsx benchmarks/chaos-runner/src/index.ts run --simulated",
    "benchmark:chaos:full": "pnpm exec tsx benchmarks/chaos-runner/src/index.ts run --simulated --max 255",
    "benchmark:chaos:stats": "pnpm exec tsx benchmarks/chaos-runner/src/index.ts stats",
    "benchmark:chaos:validate": "pnpm exec tsx benchmarks/chaos-runner/src/index.ts validate",
    "audit:wiring": "pnpm exec tsx scripts/audit-wiring.ts",
    "check:readiness": "pnpm exec tsx scripts/check-readiness.ts",
    "bench:v2:live": "pnpm exec tsx scripts/bench-v2-live.ts",
    "test:arch": "pnpm exec tsx --test packages/core/tests/architecture/architectureV2.invariants.test.ts packages/core/tests/architecture/orphanDeletion.test.ts packages/core/tests/architecture/claimHonesty.test.ts packages/core/tests/architecture/duplicationCountGuard.test.ts packages/core/tests/architecture/v2-kernel-integration.test.ts packages/core/tests/architecture/v2-fault-recovery.test.ts packages/core/tests/architecture/v2-worker-load.test.ts packages/core/tests/architecture/v2-worker-autoscale.test.ts packages/core/tests/architecture/v2-rpo-rto-drill.test.ts packages/core/tests/architecture/v2-outbox-dlq.test.ts packages/core/tests/architecture/v2-outbox-at-least-once.test.ts packages/core/tests/architecture/v2-cross-node-fencing.test.ts packages/core/tests/architecture/v2-multi-replica-simulation.test.ts packages/core/tests/architecture/v2-pagerduty-alerting.test.ts packages/core/tests/architecture/v2-cross-tenant-live-fire.test.ts packages/core/tests/atr/pauseResumeWake.test.ts && pnpm --dir packages/core exec vitest run tests/architecture/v2-event-sourcing-integrity.test.ts tests/architecture/v2-compensation-rollback.test.ts --reporter=default",
    "arch:gate": "pnpm exec tsx scripts/architecture-gate.ts",
    "contract:check": "pnpm exec tsx scripts/contract-snapshot-check.ts",
    "contract:snapshot": "pnpm exec tsx scripts/contract-snapshot-check.ts --update-baseline",
    "test:contract": "pnpm exec tsx --test packages/contracts/contract-consumer.test.ts",
    "bench:worker-claim": "pnpm exec tsx scripts/bench-worker-claim-throughput.ts",
    "benchmark:all": "pnpm exec tsx scripts/bench-wal-throughput.ts && pnpm exec tsx scripts/bench-recovery-bootstrap.ts && pnpm exec tsx scripts/bench-event-sourcing-replay.ts && pnpm exec tsx scripts/bench-slo-baseline.ts && pnpm exec tsx scripts/bench-tenant-isolation.ts && pnpm exec tsx scripts/benchmark-redteam.ts && pnpm exec tsx scripts/benchmark-agentdojo.ts --all && pnpm exec tsx scripts/check-readiness.ts",
    "rotate": "pnpm exec tsx scripts/commander-rotate.ts",
    "rotate:verify": "pnpm exec tsx scripts/verify-rotation-signoff.ts",
    "cli": "pnpm exec tsx cli.ts",
    "typecheck": "cd packages/core && npx tsc --noEmit",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:v2": "docker compose -f docker-compose.yml -f docker-compose.v2.yml --profile v2 up -d --build",
    "docker:v2:down": "docker compose -f docker-compose.yml -f docker-compose.v2.yml --profile v2 down",
    "p0:kernel-e2e": "pnpm exec tsx scripts/p0-kernel-e2e.ts",
    "p0:kernel-pg": "pnpm exec tsx --test --test-force-exit packages/kernel/src/postgres.integration.test.ts packages/worker-plane/src/e2e/gateway-kernel-worker.e2e.test.ts",
    "p0:full-loop": "pnpm exec tsx scripts/p0-full-loop.ts",
    "publish:core": "cd packages/core && pnpm publish --access public --no-git-checks",
    "release:core": "pnpm run build:core && pnpm run test:core && pnpm run publish:core",
    "lint": "npx eslint packages/core/src && pnpm run format:check && cd packages/core && npx tsc --noEmit",
    "lint:eslint": "npx eslint packages/core/src",
    "lint:prettier": "pnpm run format:check",
    "prepublish": "cd packages/core && npx tsc -p tsconfig.json",
    "format": "npx prettier --write \"packages/core/src/**/*.ts\" \"packages/core/tests/**/*.ts\" \"apps/api/src/**/*.ts\" \"apps/web/src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "format:check": "npx prettier --check \"packages/core/src/**/*.ts\" \"packages/core/tests/**/*.ts\" \"apps/api/src/**/*.ts\" \"apps/web/src/**/*.{ts,tsx}\" \"scripts/**/*.ts\""
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "better-sqlite3": "^12.11.1",
    "eslint": "^10.4.0",
    "prettier": "3.9.5",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "picomatch@<2.3.2": ">=2.3.2",
      "vite@<=6.4.1": ">=6.4.2",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@>=13.0.0 <13.0.1": ">=13.0.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "vitest@<3.2.6": ">=3.2.6",
      "typescript": "5.8.2",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
      "vite@<=6.4.2": ">=6.4.3",
      "js-yaml@<=4.1.1": ">=4.2.0"
    }
  }
}
