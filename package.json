{
  "name": "commander-monorepo",
  "version": "0.2.0",
  "description": "Commander — Multi-Agent Orchestration System (monorepo root)",
  "private": true,
  "author": "PStarH <sampan090611@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "cd packages/core && npx tsc -p tsconfig.json",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm -r dev",
    "test": "pnpm --filter @commander/core test",
    "test:core": "pnpm --filter @commander/core test",
    "test:coverage": "cd packages/core && npx --node-options='--experimental-coverage' tsx --test tests/*.test.ts",
    "test:all": "cd packages/core && npx tsx --test tests/*.test.ts",
    "cli": "npx tsx cli.ts",
    "audit:wiring": "npx tsx scripts/audit-wiring.ts",
    "typecheck": "cd packages/core && npx tsc --noEmit",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "npx eslint packages/core/src && npx prettier --check \"packages/core/src/**/*.ts\" \"apps/api/src/**/*.ts\" && cd packages/core && npx tsc --noEmit",
    "lint:eslint": "npx eslint packages/core/src",
    "format": "npx prettier --write \"packages/core/src/**/*.ts\" \"apps/api/src/**/*.ts\" \"apps/web/src/**/*.{ts,tsx}\"",
    "format:check": "npx prettier --check \"packages/core/src/**/*.ts\" \"apps/api/src/**/*.ts\" \"apps/web/src/**/*.{ts,tsx}\"",
    "prepublish": "cd packages/core && npx tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "eslint": "^10.4.0",
    "prettier": "^3.5.0",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "picomatch@<2.3.2": ">=2.3.2",
      "vite@<=6.4.1": ">=6.4.2",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@>=13.0.0 <13.0.1": ">=13.0.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "vitest@<3.2.6": ">=3.2.6",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
      "vite@<=6.4.2": ">=6.4.3",
      "js-yaml@<=4.1.1": ">=4.2.0"
    }
  }
}
