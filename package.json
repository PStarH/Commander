{
  "name": "commander-monorepo",
  "version": "0.2.0",
  "description": "Commander — Multi-Agent Orchestration System (monorepo root)",
  "private": true,
  "author": "PStarH <sampan090611@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PStarH/Commander"
  },
  "bugs": {
    "url": "https://github.com/PStarH/Commander/issues"
  },
  "homepage": "https://github.com/PStarH/Commander#readme",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "cd packages/core && npx tsc -p tsconfig.json",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm -r dev",
    "gui": "tsx packages/core/src/cli.ts gui",
    "start": "tsx packages/core/src/cli.ts gui",
    "test": "pnpm --filter @commander/core test",
    "test:core": "pnpm --filter @commander/core test",
    "test:bench": "pnpm --filter @commander/core bench",
    "test:coverage": "cd packages/core && npx --node-options='--experimental-coverage' tsx --test tests/*.test.ts",
    "test:all": "cd packages/core && npx tsx --test tests/*.test.ts",
    "benchmark:gaia": "npx tsx scripts/benchmark-gaia.ts",
    "benchmark:gaia:quick": "npx tsx scripts/benchmark-gaia.ts --quick",
    "benchmark:multiagent": "npx tsx scripts/benchmark-multiagent.ts",
    "benchmark:topology": "npx tsx scripts/benchmark-topology.ts",
    "benchmark:topology:quick": "npx tsx scripts/benchmark-topology.ts --iterations=3 --topology=single",
    "bench:wal": "npx tsx scripts/bench-wal-throughput.ts",
    "bench:wal:quick": "npx tsx scripts/bench-wal-throughput.ts --iterations=2000 --warmup=50",
    "bench:wal:regress": "npx tsx scripts/bench-wal-regress.ts",
    "benchmark:chaos": "npx tsx benchmarks/chaos-runner/src/index.ts run --dry-run",
    "benchmark:chaos:full": "npx tsx benchmarks/chaos-runner/src/index.ts run --dry-run --max 255",
    "benchmark:chaos:stats": "npx tsx benchmarks/chaos-runner/src/index.ts stats",
    "benchmark:chaos:validate": "npx tsx benchmarks/chaos-runner/src/index.ts validate",
    "audit:wiring": "npx tsx scripts/audit-wiring.ts",
    "rotate": "npx tsx scripts/commander-rotate.ts",
    "rotate:verify": "npx tsx scripts/verify-rotation-signoff.ts",
    "sign-off": "bash scripts/sign-off.sh",
    "cli": "npx tsx cli.ts",
    "typecheck": "cd packages/core && npx tsc --noEmit",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "publish:core": "cd packages/core && pnpm publish --access public --no-git-checks",
    "release:core": "pnpm run build:core && pnpm run test:core && pnpm run publish:core",
    "lint": "npx eslint packages/core/src && pnpm run format:check && cd packages/core && npx tsc --noEmit",
    "lint:eslint": "npx eslint packages/core/src",
    "lint:prettier": "pnpm run format:check",
    "prepublish": "cd packages/core && npx tsc -p tsconfig.json",
    "audit:wiring": "npx tsx scripts/audit-wiring.ts",
    "format": "npx prettier --write \"packages/core/src/**/*.ts\" \"packages/core/tests/**/*.ts\" \"apps/api/src/**/*.ts\" \"apps/web/src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "format:check": "npx prettier --check \"packages/core/src/**/*.ts\" \"packages/core/tests/**/*.ts\" \"apps/api/src/**/*.ts\" \"apps/web/src/**/*.{ts,tsx}\" \"scripts/**/*.ts\""
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.0",
    "tsx": "^4.8.1",
    "typescript-eslint": "^8.61.1",
    "prettier": "^3.5.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "picomatch@<2.3.2": ">=2.3.2",
      "vite@<=6.4.1": ">=6.4.2",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@>=13.0.0 <13.0.1": ">=13.0.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "vitest@<3.2.6": ">=3.2.6",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
      "vite@<=6.4.2": ">=6.4.3",
      "js-yaml@<=4.1.1": ">=4.2.0"
    }
  }
}
