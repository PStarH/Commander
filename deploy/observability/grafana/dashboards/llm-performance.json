{
  "title": "LLM Performance",
  "uid": "llm-performance",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_llm_tokens_total, tenant)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_llm_tokens_total{tenant=~\"$tenant\"}, model)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\"}, provider)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "title": "LLM Calls / sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m])) / avg(commander_llm_tokens_per_call_count{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"} > 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "P95 LLM Latency (ms)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(commander_llm_duration_ms_bucket{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 8000 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "LLM Error Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_llm_errors_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m])) / sum(rate(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Token Throughput",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "tps" } },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "P95 Latency by Model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(commander_llm_duration_ms_bucket{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Token Usage by Model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (model) (rate(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "tps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Error Rate by Provider",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(commander_llm_errors_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m])) / sum by (provider) (rate(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(commander_semantic_cache_events_total{outcome=\"hit\",tenant=~\"$tenant\"}[5m])) / sum(rate(commander_semantic_cache_events_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "semantic cache",
          "refId": "A"
        },
        {
          "expr": "sum(rate(commander_tool_cache_events_total{outcome=\"hit\",tenant=~\"$tenant\"}[5m])) / sum(rate(commander_tool_cache_events_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "tool cache",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Top Models by Token Usage",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (model) (rate(commander_llm_tokens_total{tenant=~\"$tenant\",model=~\"$model\",provider=~\"$provider\"}[1h]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ]
}
