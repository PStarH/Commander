{
  "title": "Cost Anomaly",
  "uid": "cost-anomaly",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_run_cost_usd_total, tenant)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "status",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_run_cost_usd_total{tenant=~\"$tenant\"}, status)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "title": "Hourly Cost Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[1h])) * 3600",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Cost vs 1h Avg (stddev)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m])) * 3600 - avg_over_time(sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m]))[1h:5m]) * 3600) / stddev_over_time(sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m]))[1h:5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Failure-Mode Cost (USD/hour)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_cost_by_failure_mode_usd{tenant=~\"$tenant\"}[1h])) * 3600",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Avg Cost per Run",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m])) / sum(rate(commander_runs_total{tenant=~\"$tenant\",status=~\"$status\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Cumulative Cost Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (status) (increase(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[$__range]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Cost by Status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (status) (rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m])) * 3600",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Cost by Failure Mode",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (failure_mode) (rate(commander_cost_by_failure_mode_usd{tenant=~\"$tenant\"}[5m])) * 3600",
          "legendFormat": "{{failure_mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Cost Anomaly Score",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "abs((sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m])) * 3600 - avg_over_time(sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m]))[1h:5m]) * 3600) / stddev_over_time(sum(rate(commander_run_cost_usd_total{tenant=~\"$tenant\",status=~\"$status\"}[5m]))[1h:5m]))",
          "legendFormat": "z-score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "Cost Distribution by Model",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (model) (rate(commander_llm_tokens_total{tenant=~\"$tenant\"}[1h]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ]
}
