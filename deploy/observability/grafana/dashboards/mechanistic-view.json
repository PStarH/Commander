{
  "title": "Mechanistic View (Ops)",
  "uid": "mechanistic-view",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "title": "EventSourcing WAL Write Latency (p95 ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, commander_event_sourcing_write_ms_bucket)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":200}] } } }
    },
    {
      "title": "WAL File Size (MB)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "commander_event_sourcing_wal_size_bytes / 1048576", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "MB", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":100},{"color":"red","value":500}] } } }
    },
    {
      "title": "DLQ Backlog",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "commander_dlq_depth", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":10},{"color":"red","value":50}] } } }
    },
    {
      "title": "Circuit Breaker Open",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "commander_circuit_breaker_open", "refId": "A" }]
    },
    {
      "title": "Event Backlog Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "commander_event_sourcing_total_events / commander_event_sourcing_total_snapshots", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":1000},{"color":"red","value":10000}] } } }
    },
    {
      "title": "Lock Contention (SQLite busy errors)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "rate(commander_sqlite_busy_errors_total[5m])", "refId": "A" }]
    },
    {
      "title": "Compensation Execution Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(commander_compensation_total{outcome=\"success\"}[5m])", "legendFormat": "Success", "refId": "A" },
        { "expr": "rate(commander_compensation_total{outcome=\"failed\"}[5m])", "legendFormat": "Failed", "refId": "B" }
      ]
    },
    {
      "title": "Audit Events Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "rate(commander_audit_events_total[5m])", "refId": "A" }]
    },
    {
      "title": "Checkpoint Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        { "expr": "rate(commander_checkpoint_total{status=\"success\"}[5m]) / rate(commander_checkpoint_total[5m])", "legendFormat": "Success Rate", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
