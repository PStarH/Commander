{
  "title": "Security Audit",
  "uid": "security-audit",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_audit_events_total, tenant)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "category",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(commander_audit_events_total{tenant=~\"$tenant\"}, category)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "title": "Audit Events / sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_audit_events_total{tenant=~\"$tenant\",category=~\"$category\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Security Errors / sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(commander_errors_total{class=~\"Security.*|.*Security.*|.*Denied.*|.*Blocked.*\",tenant=~\"$tenant\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "DLQ Depth",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(commander_dlq_depth)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Circuit Breakers Open",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(commander_circuit_breaker_open{tenant=~\"$tenant\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "title": "Audit Events by Category",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (category) (rate(commander_audit_events_total{tenant=~\"$tenant\",category=~\"$category\"}[5m]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Errors by Class",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (class) (rate(commander_errors_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Hook Failures / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (plugin) (rate(commander_hook_failures_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{plugin}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Verification Failures",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(commander_verification_results_total{passed=\"false\",tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "failures",
          "refId": "A"
        },
        {
          "expr": "sum(rate(commander_verification_results_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "total",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Compensation Outcomes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(commander_compensation_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    }
  ]
}
