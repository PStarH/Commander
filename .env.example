# =============================================================================
# Commander — Environment Configuration
# Copy to .env and fill in your values.
# Set at minimum ONE LLM provider API key.
# =============================================================================

# ── LLM Provider (set at least one) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
MIMO_API_KEY=
XIAOMI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
MISTRAL_API_KEY=
CO_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
ANYSCALE_API_KEY=
DEEPINFRA_API_KEY=

# ── Local / Self-hosted Providers ─────────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# VLLM_BASE_URL=http://localhost:8000/v1

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Cloud Replicate ───────────────────────────────────────────────────────────
# REPLICATE_API_TOKEN=

# ── Default Provider Settings ─────────────────────────────────────────────────
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ── HTTP Server ───────────────────────────────────────────────────────────────
COMMANDER_API_KEY=change-me-to-a-random-secret
PORT=4000
HOST=0.0.0.0
CORS_ORIGINS=*

# ── Multi-tenant Settings ─────────────────────────────────────────────────────
# TENANT_PROVIDER=null      # null = single-tenant (default)
# TENANT_PROVIDER=simple    # simple = static config from file
# TENANT_CONFIG_PATH=./config/tenants.json

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info            # debug | info | warn | error
# LOG_FORMAT=json           # json | text

# ── Web Search (optional, 2000 free queries/month) ────────────────────────────
# BRAVE_API_KEY=BSA_your_key_here
