# =============================================================================
# Commander — Environment Configuration
# Copy to .env and fill in your values.
# Set at minimum ONE LLM provider API key.
# =============================================================================

# ── LLM Provider (set at least one) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
MIMO_API_KEY=
XIAOMI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
MISTRAL_API_KEY=
CO_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
ANYSCALE_API_KEY=
DEEPINFRA_API_KEY=
AGNES_API_KEY=
STEPFUN_API_KEY=
MINIMAX_API_KEY=

# ── Local / Self-hosted Providers ─────────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
# VLLM_BASE_URL=http://localhost:8000/v1

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Cloud Replicate ───────────────────────────────────────────────────────────
# REPLICATE_API_TOKEN=

# ── Default Provider Settings ─────────────────────────────────────────────────
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ── Distributed EventBus ─────────────────────────────────────────────────────
# Local-first default: in-memory EventBus (no external dep).
# Set to `redis` for cross-node fan-out (requires the `distributed` compose
# profile: docker compose --profile distributed up).
# COMMANDER_EVENT_BUS_BACKEND=memory
# COMMANDER_EVENT_BUS_REDIS_URL=redis://redis:6379

# ── Observability (opt-in via compose profiles) ─────────────────────────────
# Tracing: point OTLP exporter at the Jaeger collector (compose `tracing` profile).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# Grafana admin password (compose `observability` profile). Change in production.
# GRAFANA_ADMIN_PASSWORD=admin

# ── HTTP Server ───────────────────────────────────────────────────────────────
# REQUIRED for production: a strong random secret (≥32 chars, generated with
# `openssl rand -hex 32` or a secret manager). The server hashes this at boot
# and rejects requests without a valid `Authorization: Bearer <key>` header.
# Leaving this unset or using the placeholder below is a launch blocker.
COMMANDER_API_KEY=change-me-to-a-random-secret
PORT=4000
# SECURITY: bind to 127.0.0.1 unless you have a reverse proxy / TLS terminator.
HOST=127.0.0.1
# CORS origins — comma-separated list. NEVER use '*' in production.
# CORS_ORIGINS=http://localhost:5173,https://app.example.com

# ── Multi-tenant Settings ─────────────────────────────────────────────────────
# TENANT_PROVIDER=null      # null = single-tenant (default)
# TENANT_PROVIDER=simple    # simple = static config from file
# TENANT_CONFIG_PATH=./config/tenants.json

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# ── Database Backend ──────────────────────────────────────────────────────────
# Local-first default: sqlite (file-backed, no external dependency).
# Set to `postgres` and provide DATABASE_URL to use the managed PostgreSQL
# service (compose `database` profile: docker compose --profile database up).
# API_STORE_BACKEND=sqlite
# DATABASE_URL=
# POSTGRES_USER=commander
# POSTGRES_PASSWORD=commander
# POSTGRES_DB=commander

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Default: fail closed if no OS-level sandbox (seatbelt/bwrap/docker/gvisor) is
# available. Set to true ONLY for local development or trusted environments.
# COMMANDER_ALLOW_NO_SANDBOX=false

# Require Bearer auth on /health, /health/detailed, /ready, and /metrics.
# Default is false so load-balancer probes work out of the box. Enable in
# production if these endpoints expose sensitive data.
# COMMANDER_AUTH_PROTECT_HEALTH=false

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info            # debug | info | warn | error
# LOG_FORMAT=json           # json | text

# ── Web Search (optional, 2000 free queries/month) ────────────────────────────
# BRAVE_API_KEY=BSA_your_key_here
