{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "commander-compensation",
  "title": "Commander Compensation",
  "description": "Real-time visibility into compensation step outcomes, failure rates, and anomaly detection. Aligned with prometheus/alert-rules.yml.",
  "tags": [
    "commander",
    "compensation",
    "observability"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ],
    "time_options": [
      "5m",
      "15m",
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d",
      "30d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {}
      },
      {
        "name": "tool",
        "type": "query",
        "query": "label_values(compensation_steps_total, tool)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Compensation Exhausted",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "expr": "rate(compensation_total{outcome=\"exhausted\"}[1m]) > 0",
        "step": 60,
        "titleFormat": "Exhausted: {{ tool }}",
        "tagKeys": "tool",
        "textFormat": "Compensation exhausted for {{ tool }}",
        "iconColor": "rgba(245, 54, 54, 0.9)",
        "enable": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Step Failures (5m)",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 3
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(compensation_steps_total{status=\"failed\"}[5m]))",
          "legendFormat": "Failures/sec",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exhaustions (5m)",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(compensation_total{outcome=\"exhausted\"}[5m]))",
          "legendFormat": "Exhaustions/sec",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Failure Rate (10m)",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(compensation_total{outcome=~\"failed|exhausted\"}[10m])) / sum(rate(compensation_total[10m])) > 0",
          "legendFormat": "Fail rate",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Plans Created (1h)",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "changes(compensation_planned_total[1h])",
          "legendFormat": "Plans",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Death Spiral Ratio (5m)",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(compensation_total{outcome=\"exhausted\"}[5m])) / sum(rate(compensation_planned_total[5m])) > 0",
          "legendFormat": "Exhaustion/Plan ratio",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Tools",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(compensation_steps_total > 0)",
          "legendFormat": "Tools",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Step Failure Rate by Tool",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(compensation_steps_total{status=\"failed\", tool=~\"$tool\"}[5m])",
          "legendFormat": "{{ tool }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Step Status by Tool (now)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(compensation_steps_total{status=\"failed\"}) by (tool)",
          "legendFormat": "Failed: {{ tool }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_steps_total{status=\"completed\"}) by (tool)",
          "legendFormat": "Completed: {{ tool }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_steps_total{status=\"started\"}) by (tool)",
          "legendFormat": "Started: {{ tool }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Compensation Outcomes",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(compensation_total) by (outcome)",
          "legendFormat": "{{ outcome }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Plan Risk Distribution",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(compensation_planned_total) by (risk)",
          "legendFormat": "{{ risk }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Step Status Distribution",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(compensation_steps_total) by (status)",
          "legendFormat": "{{ status }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cumulative Compensation Steps",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "stepBefore",
            "showPoints": "never"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(compensation_steps_total{status=\"completed\"})",
          "legendFormat": "Completed",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_steps_total{status=\"failed\"})",
          "legendFormat": "Failed",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Exhaustion Events",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "always"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(compensation_total{outcome=\"exhausted\"}[5m])",
          "legendFormat": "{{ tool }}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failure Rate (% over 10m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(compensation_total{outcome=~\"failed|exhausted\"}[10m])) / sum(rate(compensation_total[10m])) > 0",
          "legendFormat": "Failure rate",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Plans vs Exhaustions (5m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(compensation_planned_total[5m]))",
          "legendFormat": "Plans created / sec",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(rate(compensation_total{outcome=\"exhausted\"}[5m]))",
          "legendFormat": "Exhaustions / sec",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Per-Tool Step Summary",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(compensation_steps_total{status=\"completed\"}) by (tool)",
          "format": "table",
          "instant": true,
          "legendFormat": "Completed",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_steps_total{status=\"failed\"}) by (tool)",
          "format": "table",
          "instant": true,
          "legendFormat": "Failed",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_steps_total{status=\"started\"}) by (tool)",
          "format": "table",
          "instant": true,
          "legendFormat": "Started",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_total{outcome=\"exhausted\"}) by (tool)",
          "format": "table",
          "instant": true,
          "legendFormat": "Exhausted",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "sum(compensation_planned_total) by (tool)",
          "format": "table",
          "instant": true,
          "legendFormat": "Plans",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "metric": true
            },
            "indexByName": {
              "tool": 0,
              "Plans": 1,
              "Started": 2,
              "Completed": 3,
              "Failed": 4,
              "Exhausted": 5
            }
          }
        }
      ]
    }
  ]
}