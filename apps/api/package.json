  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@commander/contracts": "workspace:*",
    "@commander/core": "workspace:*",
    "@commander/kernel": "workspace:*",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
