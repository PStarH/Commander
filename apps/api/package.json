    "dev": "ts-node-dev src/index.ts",
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "pretest": "pnpm --filter @commander/core --filter @commander/kernel build && pnpm build",
    "test": "node --import tsx --test test/*.test.cjs test/*.test.ts",
    "test:integration": "npx -p tsx tsx scripts/run-integration-tests.ts"
  },
